{
	"manifest_version": 3,
	"name": "Unpin",
	"version": "1.0.0",
	"description": "Hide the home feed, related pins, and board suggestions on Pinterest.",
	"icons": {
		"16": "icon-16.png",
		"32": "icon-32.png",
		"48": "icon-48.png",
		"128": "icon-128.png"
	},
	"action": {
		"default_popup": "popup.html",
		"default_title": "Unpin Settings",
		"default_icon": "icon-32.png"
	},
	"permissions": [
		"storage"
	],
	"browser_specific_settings": {
		"gecko": {
			"id": "unpin@goldyapps.com",
			"strict_min_version": "142.0",
			"data_collection_permissions": {
				"required": [ "none" ]
			}
		}
	},
	"content_scripts": [
		{
			"matches": [
				"*://*.pinterest.com/*",
				"*://*.pinterest.co.uk/*",
				"*://*.pinterest.ca/*",
				"*://*.pinterest.com.au/*"
			],
			"js": [ "content.js" ],
			"run_at": "document_start"
		}
	]
}
